{
  "env": {
    "browser": true,
    "jquery": true,
    "es6": true
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "no-unreachable": "warn",
    "no-unused-expressions": "warn",
    "no-empty": "warn",
    "no-redeclare": "warn",
    "no-var": "off",
    "eqeqeq": "warn",
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["index.js"],
      "env": {
        "node": true,
        "browser": false
      }
    }
  ]
}
